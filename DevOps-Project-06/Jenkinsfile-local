pipeline {
    agent {
        label 'maven'
    }

    stages {

        stage('Build') {
            steps {
                dir('DevOps-Project-06') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            dir('DevOps-Project-06') {
               withSonarQubeEnv('sonarqube-local') {
                  sh '''
                     mvn sonar:sonar \
                     -Dsonar.projectKey=sample-app \
                     -Dsonar.projectName=sample-app
                  '''
                }
            }
        }
    }
}
