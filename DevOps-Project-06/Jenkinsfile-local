pipeline {
    agent {
        label 'maven'
    }

    stages {

        stage('Build') {
            steps {
                dir('DevOps-Project-06') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Test') {
            steps {
                dir('DevOps-Project-06') {
                    sh 'mvn test'
                }
            }
        }

    }
}
